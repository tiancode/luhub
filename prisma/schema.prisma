// luhub —— 视频资源聚合站 数据模型
// 文档: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// 资源站（采集来源）
model Source {
  id         Int      @id @default(autoincrement())
  name       String   @unique
  apiUrl     String
  kind       String   @default("maccms_json") // maccms_json | maccms_xml | html
  adapter    String? // 仅 html 源:Python 适配器名(crawler/registry.py),如 "yhdm";空=用 maccms 接口
  enabled    Boolean  @default(true)
  lastSyncAt DateTime?
  createdAt  DateTime @default(now())

  videos       Video[]
  categoryMaps CategoryMap[]
  collectRuns  CollectRun[]
}

/// 采集任务运行记录
model CollectRun {
  id         Int       @id @default(autoincrement())
  sourceId   Int
  status     String    @default("running") // running | success | failed | paused
  pages      Int?
  hours      Int?
  full       Boolean   @default(false)
  videos     Int       @default(0)
  categories Int       @default(0)
  lastPage   Int       @default(0) // 已完整入库的页码（maccms 暂停后从此页+1 续采）
  message    String? // onProgress 累加的进度日志 / 错误信息
  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  source Source @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId, startedAt])
}

/// 本站统一分类
model Category {
  id        Int    @id @default(autoincrement())
  name      String
  slug      String @unique
  group     String @default("other") // movie | tv | variety | anime | other
  sortOrder Int    @default(0)

  videos       Video[]
  categoryMaps CategoryMap[]
}

/// 资源站 type_id -> 本站分类 的映射
model CategoryMap {
  id           Int    @id @default(autoincrement())
  sourceId     Int
  remoteTypeId Int
  remoteName   String?
  categoryId   Int

  source   Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([sourceId, remoteTypeId])
}

/// 影片
model Video {
  id          Int      @id @default(autoincrement())
  sourceId    Int
  sourceVodId String // 资源站的 vod_id
  name        String
  slug        String?
  pic         String?
  remarks     String? // vod_remarks，如“更新至12集”
  year        Int?
  area        String?
  lang        String?
  actor       String?
  director    String?
  content     String?
  score       Float?
  categoryId  Int?
  releasedAt  DateTime? // vod_time
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  source         Source          @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  playSources    PlaySource[]
  cachedEpisodes CachedEpisode[]
  favorites      Favorite[]
  watchHistory   WatchHistory[]

  @@unique([sourceId, sourceVodId])
  @@index([categoryId])
  @@index([year])
  @@index([area])
  @@index([releasedAt])
}

/// 播放线路（对应 vod_play_from 的每一组）
model PlaySource {
  id        Int    @id @default(autoincrement())
  videoId   Int
  fromName  String
  sortOrder Int    @default(0)

  video    Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  episodes Episode[]

  @@index([videoId])
}

/// 剧集
model Episode {
  id           Int    @id @default(autoincrement())
  playSourceId Int
  name         String
  url          String
  sortOrder    Int    @default(0)

  playSource PlaySource @relation(fields: [playSourceId], references: [id], onDelete: Cascade)

  @@index([playSourceId])
}

/// 本地缓存的剧集（前台播放时按需生成，独立于采集会重建的 PlaySource/Episode）。
/// 以稳定键 (videoId, lineName, epName) 记录，故采集重建播放线路时不受影响。
model CachedEpisode {
  id        Int      @id @default(autoincrement())
  videoId   Int
  lineName  String // 原始线路名（vod_play_from 的某条），如 "线路A"
  epName    String // 集数名，如 "第01集"
  sourceUrl String // 缓存时的远程地址（mp4 或 m3u8）
  status    String   @default("pending") // pending | downloading | ready | failed
  format    String? // mp4 | hls（来源类型，产物始终是 mp4）
  localUrl  String? // 对外播放地址，如 /videos/电视剧/...（分段 encodeURIComponent）
  relPath   String? // 人类可读的相对路径（便于运维/排错）
  bytes     BigInt? // 文件大小（视频可超 2GB，故用 BigInt）
  error     String?
  attempts  Int      @default(0) // 失败重试计数；超过上限后跳过该坏流不再下载
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, lineName, epName])
  @@index([videoId, status])
}

/// 匿名访客的收藏。无登录，靠 cookie(luhub_vid)里的随机 visitorId 定位用户。
model Favorite {
  id        Int      @id @default(autoincrement())
  visitorId String // cookie 里的随机 UUID
  videoId   Int
  createdAt DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([visitorId, videoId])
  @@index([visitorId, createdAt])
}

/// 匿名访客的观看历史（每访客每影片一条，记录最近线路/集与续播进度）。
model WatchHistory {
  id        Int      @id @default(autoincrement())
  visitorId String
  videoId   Int
  lineName  String? // 最近播放的线路名（vod_play_from 的某条）
  epName    String? // 最近播放的集名
  epIndex   Int      @default(0) // 集在该线路里的序号（续播定位，线路重建后兜底）
  position  Float    @default(0) // 播放进度（秒）
  duration  Float? // 该集总时长（秒），用于进度条/判断是否看完
  updatedAt DateTime @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([visitorId, videoId])
  @@index([visitorId, updatedAt])
}
