# 数据库连接串
# 开发默认用本地 SQLite；上线可切换为 PostgreSQL/MySQL（需同步修改 prisma/schema.prisma 的 datasource provider）
DATABASE_URL="file:./dev.db"

# 采集后台登录密码（必填，否则 /admin 始终上锁）
ADMIN_PASSWORD="change-me"
# 可选：派生 cookie 令牌的密钥；不填则用 ADMIN_PASSWORD 自身派生
# ADMIN_SECRET=""
# 可选：强制给后台 cookie 加 Secure(仅 HTTPS 回传)。默认按 x-forwarded-proto 自动判断:
# 反代终止 TLS 会自动开启;纯 HTTP(如内网按 IP 访问)保持关闭,否则登录后会被踢回登录页。
# 仅当你「直连 HTTPS 且无反代透传该头」时才需要手动设为 1。
# ADMIN_COOKIE_SECURE="1"

# 可选：HTML 采集(html 适配器,如 yhdm)所用的 Python 解释器，需装好 crawler/requirements.txt(httpx/bs4)。
# 后台 /admin 与 collect:py 会 spawn 它;留空则用 PATH 上的 python3。
# PYTHON_BIN="./crawler/.venv/bin/python"

# 采集封面存储目录(默认 public/covers；Docker 里为 /data/covers)。
# 站内 /covers/<file> 由路由处理器直接从此目录流式返回(不经 public/ 静态托管)。
# COVERS_DIR="/data/covers"

# —— 播放即缓存（前台播放某集时，后台把该集永久缓存为本地 mp4，并多出一条「缓存线路」）——
# 缓存视频目录(默认 public/videos；Docker 里为 /data/videos)。
# 站内 /videos/<...> 由路由处理器直接从此目录流式返回(支持 Range，可拖动进度)。
# VIDEOS_DIR="/data/videos"
# m3u8 经 ffmpeg 合并成 mp4 所用的可执行文件；留空用 PATH 上的 ffmpeg(镜像已内置)。
# FFMPEG_BIN="ffmpeg"
# 设为 1 完全关闭播放即缓存。
# DISABLE_VIDEO_CACHE="0"
# 同时进行的缓存任务数(默认 1，串行；SQLite 单写+避免打爆源站，一般不必调高)。
# VIDEO_CACHE_CONCURRENCY="1"
# 单个缓存任务超时毫秒(默认 1800000 = 30 分钟)。
# VIDEO_CACHE_TIMEOUT_MS="1800000"
# 数据停滞超时毫秒(默认 60000)：一段时间没有任何数据/进度即判定为坏流，快速放弃。
# VIDEO_CACHE_STALL_MS="60000"
# 同一坏流连续失败多少次后跳过、不再下载(默认 3；地址变更会重置计数)。
# VIDEO_CACHE_MAX_ATTEMPTS="3"
